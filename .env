# ===== Настройки базы данных (PostgreSQL) =====
# Имя базы данных, которую вы создали в pgAdmin
DB_NAME=bookstore2

# Ваш логин в PostgreSQL (обычно postgres)
DB_USER=postgres

# Ваш пароль от PostgreSQL
DB_PASS=privet

# Адрес сервера БД. localhost — это ваш компьютер
DB_HOST=localhost

# Стандартный порт PostgreSQL — 5432
DB_PORT=5432

# ===== Настройки сервера сайта =====
# Порт, на котором будет запущен ваш сайт (http://localhost:3000)
PORT=3000

# ===== Безопасность (Авторизация) =====
# JWT_SECRET — это секретный «ключ», который используется для создания токенов входа.
# Когда пользователь входит в аккаунт, сервер создает для него уникальную «печать» (токен),
# используя этот ключ. Это нужно, чтобы злоумышленники не могли подделать вход в систему.
# Вы можете написать сюда любую длинную случайную строку.
JWT_SECRET=your_very_secret_key_123_change_me_in_production
